---
import '../styles/global.css';
import { getCopy, type Locale } from '../i18n/copy';

interface Props {
  title?: string;
  description?: string;
}
const lang = (Astro.currentLocale ?? 'en') as Locale;
const t = getCopy(lang);
const { title = t.meta.title, description = t.meta.description } = Astro.props;
// language toggle target (en is unprefixed, zh lives at /zh)
const otherLocaleHref = lang === 'zh' ? '/' : '/zh/';
const otherLocaleLabel = lang === 'zh' ? 'EN' : '中文';
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#F6F4EF" />

    {/* link previews (iMessage / Slack / social) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Verren" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={t.meta.ogDescription} />
    <meta property="og:url" content={lang === 'zh' ? 'https://verren.app/zh/' : 'https://verren.app/'} />

    {/* locale alternates for search engines */}
    <link rel="alternate" hreflang="en" href="https://verren.app/" />
    <link rel="alternate" hreflang="zh" href="https://verren.app/zh/" />
    <link rel="alternate" hreflang="x-default" href="https://verren.app/" />
    <meta property="og:image" content="https://verren.app/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={t.meta.ogDescription} />
    <meta name="twitter:image" content="https://verren.app/og.png" />

    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* One typeface, one weight — General Sans 400 (untitledSans substitute).
        DM Mono only for the tiny eyebrow chips / card labels. */}
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

    {/* Arm animation start-states ONLY when JS is live (webview-safe). */}
    <script is:inline>
      document.documentElement.classList.add('js-anim');
    </script>

    {/* Locale adaptation — runs before paint. An explicit toggle choice
        (localStorage) always wins; otherwise zh-preferring browsers landing
        on / are sent to /zh/ once. Static-host friendly (no server neg.). */}
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('v-locale');
          var onZh = location.pathname === '/zh' || location.pathname.indexOf('/zh/') === 0;
          if (pref === 'en' && onZh) location.replace('/');
          else if (pref === 'zh' && !onZh) location.replace('/zh/');
          else if (!pref && !onZh) {
            var langs = navigator.languages || [navigator.language || ''];
            for (var i = 0; i < langs.length; i++) {
              if (/^zh/i.test(langs[i])) { location.replace('/zh/'); break; }
              if (/^en/i.test(langs[i])) break; // en outranks zh in their list
            }
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    {/* hero atmosphere — fixed gradient wash; fades out as you scroll (scrubbed) */}
    <div class="v-wash" id="v-wash" aria-hidden="true"></div>

    <header class="v-header" data-header>
      <div class="v-container flex h-[60px] items-center justify-between gap-6">
        <a class="v-wordmark no-underline" href="#top">Verren</a>
        <nav class="hidden items-center gap-1 md:flex">
          {t.nav.links.map((l) => <a class="v-navlink" href={l.href}>{l.label}</a>)}
          <a class="v-navlink v-lang" href={otherLocaleHref}>{otherLocaleLabel}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="v-btn v-btn--primary hidden sm:inline-flex" href="#waitlist">{t.nav.cta} <span class="arrow">→</span></a>
          <button id="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" class="v-burger md:hidden">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
      <div id="nav-menu" class="v-menu hidden md:hidden">
        <div class="v-container flex flex-col gap-1 pb-4">
          {t.nav.links.map((l) => <a class="v-navlink" href={l.href} data-nav-link>{l.label}</a>)}
          <a class="v-navlink v-lang" href={otherLocaleHref} data-nav-link>{otherLocaleLabel}</a>
          <a class="v-btn v-btn--primary mt-2 w-max" href="#waitlist" data-nav-link>{t.nav.cta} <span class="arrow">→</span></a>
        </div>
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer class="border-t border-hairline py-10">
      <div class="v-container flex flex-col gap-1.5">
        <div class="text-sm text-ink-sub">{t.footer.line1}</div>
        <div class="text-xs text-ink-subtle">{t.footer.line2}</div>
      </div>
    </footer>

    <style>
      .v-wash {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: linear-gradient(to bottom, var(--v-wash-top), var(--v-wash-bottom) 62%, var(--v-bg) 92%);
        pointer-events: none;
      }
      /* merged into the page at the very top; translucent blur bar once scrolled
         (seedzeng.com pattern) — readable over white sections */
      .v-header {
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid transparent;
        transition: background 250ms ease, border-color 250ms ease;
      }
      .v-header[data-scrolled],
      .v-header.menu-open {
        background: color-mix(in srgb, var(--v-bg) 78%, transparent);
        -webkit-backdrop-filter: blur(14px);
        backdrop-filter: blur(14px);
        border-bottom-color: var(--v-hairline);
      }
      .v-burger {
        /* unlayered component CSS outranks Tailwind's md:hidden utility, so
           the desktop hide must live here too */
        display: inline-flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 28px;
        height: 28px;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--v-ink-title);
      }
      .v-burger span {
        display: block;
        height: 1.5px;
        width: 20px;
        background: currentColor;
        border-radius: 1px;
      }
      @media (min-width: 768px) {
        .v-burger {
          display: none;
        }
      }
      .v-wordmark {
        font-family: var(--font-hand);
        font-size: 24px;
        font-weight: 600;
        line-height: 1;
        color: var(--v-ink-title);
        letter-spacing: 0.01em;
        transform: rotate(-1.5deg);
        display: inline-block;
        padding-bottom: 2px; /* optical centering for Caveat's baseline */
      }
      .v-navlink {
        text-decoration: none;
        font-size: var(--text-sm);
        color: var(--v-ink-sub);
        padding: 5px 10px;
        border-radius: var(--radius-md);
        transition: color 200ms, background 200ms;
      }
      .v-navlink:hover {
        color: var(--v-ink-title);
        background: var(--v-fill);
      }
    </style>

    <script>
      // ---- nav: merged at top, translucent bar once scrolled; mobile menu ----
      const header = document.querySelector<HTMLElement>('[data-header]');
      if (header) {
        const syncHeader = () => header.toggleAttribute('data-scrolled', window.scrollY > 4);
        syncHeader();
        addEventListener('scroll', syncHeader, { passive: true });
        const toggle = document.getElementById('nav-toggle');
        const menu = document.getElementById('nav-menu');
        const closeMenu = () => {
          menu?.classList.add('hidden');
          header.classList.remove('menu-open');
          toggle?.setAttribute('aria-expanded', 'false');
        };
        toggle?.addEventListener('click', () => {
          const open = menu?.classList.toggle('hidden') === false;
          header.classList.toggle('menu-open', open);
          toggle.setAttribute('aria-expanded', String(open));
        });
        document.querySelectorAll('[data-nav-link]').forEach((a) => a.addEventListener('click', closeMenu));

        // language toggle: an explicit choice overrides browser-language detection
        document.querySelectorAll<HTMLAnchorElement>('.v-lang').forEach((a) =>
          a.addEventListener('click', () => {
            try {
              localStorage.setItem('v-locale', a.getAttribute('href')?.startsWith('/zh') ? 'zh' : 'en');
            } catch (_) {}
          })
        );
      }

      // ---- Pattern 1: one-shot reveals (IntersectionObserver → CSS transition) ----
      let ioFired = false;
      const revealIO = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            ioFired = true;
            const el = e.target as HTMLElement;
            const d = el.dataset.revealDelay;
            if (d) el.style.setProperty('--reveal-delay', d + 'ms');
            el.classList.add('in');
            revealIO.unobserve(el);
          }
        },
        { threshold: 0, rootMargin: '0px 0px -12% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealIO.observe(el));

      // Webview safety net: ONLY if IO never fired (suspended webview), snap
      // everything visible with transitions off — a suspended webview freezes
      // mid-transition at opacity 0 otherwise. In live browsers IO handles
      // every reveal, including below the fold on scroll.
      setTimeout(() => {
        if (ioFired) return;
        document.querySelectorAll('.js-anim .reveal:not(.in)').forEach((el) => el.classList.add('in', 'in--snap'));
      }, 600);

      // ---- Pinned vertical page scrub ([data-vpin]) ----
      // Pages cross-fade + slide vertically as a linear function of scroll
      // progress across the tall wrapper. Reverses on scroll-up.
      const vpins = Array.from(document.querySelectorAll<HTMLElement>('[data-vpin]')).map((wrap) => {
        const pages = Array.from(wrap.querySelectorAll<HTMLElement>('.vpin-page'));
        const nums = Array.from(wrap.querySelectorAll<HTMLElement>('.vpin-num'));
        wrap.style.setProperty('--pages', String(pages.length));
        // index numbers jump to their page's scroll position
        nums.forEach((n, i) => {
          n.addEventListener('click', () => {
            const r = wrap.getBoundingClientRect();
            const scrollable = r.height - window.innerHeight;
            const target = window.scrollY + r.top + (i / Math.max(1, pages.length - 1)) * scrollable;
            window.scrollTo({ top: target, behavior: 'smooth' });
          });
        });
        return { wrap, pages, nums };
      });
      const mqDesktop = matchMedia('(min-width: 900px)');
      const mqReduced = matchMedia('(prefers-reduced-motion: reduce)');
      function updateVpins() {
        for (const { wrap, pages, nums } of vpins) {
          if (!mqDesktop.matches || mqReduced.matches) {
            for (const pg of pages) {
              pg.style.opacity = '';
              pg.style.transform = '';
              pg.style.pointerEvents = '';
              pg.style.visibility = '';
            }
            continue;
          }
          const r = wrap.getBoundingClientRect();
          const scrollable = r.height - window.innerHeight;
          const p = Math.min(1, Math.max(0, -r.top / scrollable));
          const t = p * (pages.length - 1);
          pages.forEach((pg, i) => {
            const off = Math.max(-1, Math.min(1, t - i));
            // Pages travel like real pages: incoming rises from ~60% of a
            // viewport below while the outgoing exits above — spatially
            // separate the whole way, so the cross-fade can overlap in time
            // without overlapping in space.
            const a = Math.abs(off);
            const raw = Math.min(1, Math.max(0, (0.65 - a) / 0.4));
            const vis = raw * raw * (3 - 2 * raw); // smoothstep
            pg.style.opacity = vis.toFixed(3);
            pg.style.transform = `translate3d(0, ${(-off * window.innerHeight * 0.5).toFixed(1)}px, 0)`;
            pg.style.pointerEvents = vis > 0.5 ? 'auto' : 'none';
            pg.style.visibility = vis === 0 ? 'hidden' : '';
          });
          const active = Math.min(pages.length - 1, Math.round(t));
          nums.forEach((n, i) => n.classList.toggle('on', i === active));
        }
      }
      if (vpins.length) {
        let vpinTicking = false;
        const onVpinScroll = () => {
          if (vpinTicking) return;
          vpinTicking = true;
          requestAnimationFrame(() => {
            updateVpins();
            vpinTicking = false;
          });
        };
        addEventListener('scroll', onVpinScroll, { passive: true });
        addEventListener('resize', onVpinScroll, { passive: true });
        updateVpins();
      }

      // ---- Pointer tilt (ported from Clawdia's tilt.js) ----
      // .v-tilt surfaces rotate toward the cursor with a sheen; delegated on
      // document (one listener), rAF-batched, mouse-only, reduced-motion-off.
      (() => {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const SEL = '.v-tilt';
        const MAX = 4, SCALE = 1.015, PERSP = 1000;
        let raf = 0;
        let queued: { tile: HTMLElement; x: number; y: number } | null = null;
        let active: HTMLElement | null = null;
        const paint = () => {
          raf = 0;
          if (!queued) return;
          const { tile, x, y } = queued;
          const r = tile.getBoundingClientRect();
          if (!r.width || !r.height) return;
          const px = (x - r.left) / r.width - 0.5;
          const py = (y - r.top) / r.height - 0.5;
          tile.style.transform =
            `perspective(${PERSP}px) rotateX(${(-py * MAX * 2).toFixed(2)}deg)` +
            ` rotateY(${(px * MAX * 2).toFixed(2)}deg) scale(${SCALE})`;
          tile.style.setProperty('--tilt-mx', `${((px + 0.5) * 100).toFixed(1)}%`);
          tile.style.setProperty('--tilt-my', `${((py + 0.5) * 100).toFixed(1)}%`);
        };
        const resetTile = (tile: HTMLElement) => {
          tile.classList.remove('tilting');
          tile.style.transform = '';
          tile.style.willChange = '';
        };
        document.addEventListener(
          'pointermove',
          (e) => {
            if (e.pointerType && e.pointerType !== 'mouse') {
              if (active) { resetTile(active); active = null; }
              return;
            }
            const tile = (e.target as Element | null)?.closest?.(SEL) as HTMLElement | null;
            if (active && active !== tile) { resetTile(active); active = null; }
            if (!tile) return;
            if (active !== tile) {
              active = tile;
              tile.classList.add('tilting');
              tile.style.willChange = 'transform';
            }
            queued = { tile, x: e.clientX, y: e.clientY };
            if (!raf) raf = requestAnimationFrame(paint);
          },
          { passive: true }
        );
        const drop = () => { if (active) { resetTile(active); active = null; } };
        document.addEventListener('pointerleave', drop);
        addEventListener('scroll', drop, { passive: true });
      })();

      // ---- Pattern 2: scroll-scrub — hero wash fades across the first viewport ----
      const wash = document.getElementById('v-wash');
      const reduced = window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (wash && !reduced) {
        let ticking = false;
        const update = () => {
          const p = Math.min(1, Math.max(0, window.scrollY / (window.innerHeight * 1.2)));
          wash.style.opacity = String(1 - p);
        };
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        };
        addEventListener('scroll', onScroll, { passive: true });
        addEventListener('resize', onScroll, { passive: true });
        update();
      }
    </script>
  </body>
</html>
