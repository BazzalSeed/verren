---
/**
 * Features — pinned three-page showcase (shared [data-vpin] driver).
 * Each page's visual is a FLOW diagram, not a fake UI screenshot:
 *   01 — sources (email/meeting/note/doc) light up and feed the profile
 *   02 — the book as a list; rows expand to show the full briefing inside
 *   03 — approval queue → items move to a "Done · logged" ledger
 * All animation is setInterval-driven (webview-safe), fully rendered at
 * rest, off under reduced-motion. All mock data obviously fictional.
 */
import SectionHeader from './SectionHeader.astro';
import { getCopy } from '../i18n/copy';
const t = getCopy(Astro.currentLocale);
const f = t.features;
const [p1, p2, p3] = f.pages;
---

<section id="features" class="pt-24 md:pt-32">
  <div class="vpin" data-vpin>
    <div class="vpin-sticky">
      <div class="vpin-head">
        <SectionHeader chip={f.chip} lead={f.title}>
          <div class="vpin-index" slot="aside" aria-hidden="true">
            {f.pages.map((p) => <span class="vpin-num">{p.num}</span>)}
          </div>
        </SectionHeader>
      </div>

      <!-- ============ 01 — The data enters itself ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p1.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p1.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p1.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div class="fp-visual v-tilt fp-flow" aria-hidden="true">
                <div class="flow-sources">
                  <div class="flow-label">{f.flow.sourcesLabel}</div>
                  {f.flow.sources.map((src) => (
                    <div class="flow-src">
                      <span class="flow-kind">{src.kind}</span>
                      <span class="flow-t">{src.text}</span>
                    </div>
                  ))}
                  <div class="flow-foot">{f.flow.foot}</div>
                </div>
                <div class="flow-arrow">
                  <span class="flow-arrow-line"></span>
                  <span class="flow-arrow-tag">{f.flow.seam}</span>
                  <span class="flow-arrow-line"></span>
                </div>
                <div class="flow-profile">
                  <div class="fprof-eyebrow">{f.flow.profile.eyebrow}</div>
                  <div class="fprof-name">{f.flow.profile.name}</div>
                  <div class="fprof-sub">{f.flow.profile.sub}</div>
                  <div class="fprof-divider"></div>
                  {f.flow.profile.rows.map((r) => (
                    <div class="flow-p-row"><span class="fpv-chip">{r.chip}</span> {r.text}</div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 02 — It knows your book ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p2.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p2.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p2.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div class="fp-visual v-tilt fp-book" aria-hidden="true">
                <div class="book3">
                  <div class="book3-list">
                    <div class="flow-label">{f.book.listLabel}</div>
                    {f.book.items.map((it) => (
                      <div class:list={['book3-item', it.on && 'on']}><span>{it.name}</span><span class:list={['fpv-chip', it.statusClass]}>{it.status}</span></div>
                    ))}
                    <div class="flow-foot">{f.book.foot}</div>
                  </div>
                  <div class="book3-details">
                    {f.book.details.map((d, i) => (
                      <div class:list={['book3-detail', i === 0 && 'on']}>
                        <div class="fprof-eyebrow">{d.eyebrow}</div>
                        <div class="fprof-name">{d.name}</div>
                        <div class="fprof-sub">{d.sub}</div>
                        <div class="fprof-divider"></div>
                        <div class="book2-sec">{d.sec1}</div>
                        {d.facts.map((fact) => (
                          <div class="bk-row"><span class="fpv-chip">{fact.chip}</span> {fact.text}</div>
                        ))}
                        <div class="book2-sec">{d.sec2}</div>
                        <div class="book2-brief">{d.brief}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 03 — It does the work ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p3.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p3.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p3.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div
                class="fp-visual v-tilt fp-appr"
                aria-hidden="true"
                data-pending-fmt={f.appr.pendingFmt}
                data-allclear={f.appr.allClear}
                data-approve={f.appr.approve}
                data-approved={f.appr.approved}
              >
                <div class="appr-col appr-queue">
                  <div class="flow-label">
                    {f.appr.queueLabel}
                    <span class="appr-count">{f.appr.pendingFmt.replace('{n}', String(f.appr.items.length))}</span>
                  </div>
                  {f.appr.items.map((item) => (
                    <div class="appr-item">
                      <span class="appr-t">{item}</span>
                      <span class="fpv-approve">{f.appr.approve}</span>
                    </div>
                  ))}
                </div>
                <div class="appr-col appr-done">
                  <div class="flow-label">{f.appr.doneLabel}</div>
                  {f.appr.done.map((d) => <div class="adone-row">{d}</div>)}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fp-num {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: var(--text-xs);
    color: var(--v-ink-subtle);
  }

  /* ---------- shared visual chrome ---------- */
  .fp-visual {
    border-radius: 14px;
    background: var(--v-card);
    border: 1px solid var(--v-border-subtle);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.05);
    padding: 22px 24px;
  }
  .fpv-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 13px;
    border-bottom: 1px solid var(--v-hairline);
    margin-bottom: 8px;
  }
  .fpv-title {
    font-size: var(--text-base);
    letter-spacing: -0.01em;
    color: var(--v-ink-title);
  }
  .fpv-meta {
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
  }
  .fpv-chip {
    flex: none;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: var(--radius-sm);
    background: var(--v-brand-wash);
    color: var(--v-brand);
  }
  .fpv-chip.chip-current {
    background: #e9f6ee;
    color: #2e7d4f;
  }
  .fpv-chip.chip-risk {
    background: rgba(216, 138, 32, 0.14);
    color: #a06008;
  }

  /* the extraction seam "works" while a transfer is in flight */
  @keyframes v-working {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .flow-arrow-tag {
    transition: color 300ms ease;
  }
  .flow-arrow-tag.working {
    color: var(--v-brand);
    animation: v-working 0.9s ease-in-out infinite;
  }

  .flow-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin-bottom: 10px;
  }
  .flow-foot {
    margin-top: 12px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
  }

  /* ---------- 01: sources → profile ---------- */
  .fp-flow {
    display: grid;
    grid-template-columns: 1fr auto 1.2fr;
    gap: 16px;
    align-items: stretch;
    min-height: 380px;
  }
  .flow-src {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 9px 11px;
    border: 1px solid var(--v-hairline);
    border-radius: 8px;
    margin-bottom: 8px;
    transition: border-color 400ms ease, background 400ms ease;
  }
  .flow-src.on {
    border-color: var(--v-brand-soft);
    background: var(--v-brand-wash);
  }
  .flow-kind {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
  }
  .flow-t {
    font-size: var(--text-xs);
    color: var(--v-ink-title);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .flow-arrow-line {
    width: 1px;
    flex: 1;
    background: var(--v-border-moderate);
  }
  .flow-arrow-tag {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--v-ink-hint);
    writing-mode: vertical-rl;
  }
  .flow-live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
  }
  .flow-live .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4caf6d;
  }
  .flow-profile {
    border: 1px solid var(--v-border-subtle);
    border-radius: 10px;
    background: var(--v-surface);
    padding: 16px 18px;
    align-self: start;
  }
  .fprof-eyebrow {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin-bottom: 7px;
  }
  .fprof-name {
    font-size: var(--text-h3);
    letter-spacing: -0.015em;
    color: var(--v-ink-title);
  }
  .fprof-sub {
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
    margin-top: 2px;
  }
  .fprof-divider {
    height: 1px;
    background: var(--v-hairline);
    margin: 12px 0 4px;
  }
  .flow-p-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    color: var(--v-ink-title);
    padding: 8px 2px;
    border-bottom: 1px solid var(--v-hairline);
  }
  /* with JS live, rows genuinely don't exist until their source is read —
     they grow in as Verren writes them (no-JS/reduced-motion: complete card) */
  :global(.js-anim) .flow-p-row {
    opacity: 0;
    max-height: 0;
    padding-block: 0;
    border-bottom-width: 0;
    overflow: hidden;
    transition:
      opacity 500ms ease,
      background 500ms ease,
      max-height 450ms cubic-bezier(0.22, 1, 0.36, 1),
      padding 450ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.js-anim) .flow-p-row.written {
    opacity: 1;
    max-height: 52px;
    padding-block: 8px;
    border-bottom-width: 1px;
  }
  .flow-p-row.landing {
    background: var(--v-brand-wash);
    border-radius: 6px;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.js-anim) .flow-p-row {
      opacity: 1;
      max-height: none;
      padding: 8px 2px;
      border-bottom-width: 1px;
      overflow: visible;
      transition: none;
    }
  }

  /* ---------- 02: the book — master list + full profile (static) ---------- */
  .book3 {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 20px;
    align-items: start;
  }
  .book3-list {
    border-right: 1px solid var(--v-hairline);
    padding-right: 20px;
  }
  .book3-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 11px 8px;
    font-size: var(--text-sm);
    color: var(--v-ink-title);
    border-bottom: 1px solid var(--v-hairline);
  }
  .book3-item:last-of-type {
    border-bottom: none;
  }
  .book3-item.on {
    background: var(--v-fill);
    border-radius: 6px;
  }
  .book3-detail {
    border: 1px solid var(--v-border-subtle);
    border-radius: 10px;
    background: var(--v-surface);
    padding: 16px 18px;
    display: none;
  }
  .book3-detail.on {
    display: block;
    animation: book3-in 350ms ease;
  }
  @keyframes book3-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .book3-item {
    transition: background 250ms ease;
  }
  .book3-item.pressed {
    background: var(--v-brand-wash);
    border-radius: 6px;
  }
  @media (prefers-reduced-motion: reduce) {
    .book3-detail.on { animation: none; }
  }
  .book2-sec {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin: 12px 0 6px;
  }
  .bk-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    color: var(--v-ink-title);
    padding: 7px 0;
    border-bottom: 1px solid var(--v-hairline);
  }
  .bk-row:last-of-type {
    border-bottom: none;
  }
  .book2-brief {
    font-size: var(--text-xs);
    line-height: 1.55;
    color: var(--v-ink-sub);
    background: var(--v-card);
    border: 1px solid var(--v-hairline);
    border-radius: 8px;
    padding: 10px 12px;
  }
  @media (max-width: 899px) {
    .book3 {
      grid-template-columns: 1fr;
    }
    .book3-list {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid var(--v-hairline);
      padding-bottom: 12px;
      margin-bottom: 4px;
    }
  }

  /* ---------- 03: approve → done ledger ---------- */
  .fp-appr {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .appr-col:first-child {
    border-right: 1px solid var(--v-hairline);
    padding-right: 20px;
  }
  .appr-count {
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
  }
  .appr-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 10px 2px;
    border-bottom: 1px solid var(--v-hairline);
    transition: opacity 450ms ease, transform 450ms ease, background 400ms ease;
    border-radius: 6px;
  }
  .appr-item.fv-active {
    background: var(--v-fill);
  }
  /* approved items stay put — just crossed off (no layout motion) */
  .appr-item.crossed .appr-t {
    text-decoration: line-through;
    text-decoration-color: var(--v-ink-subtle);
    color: var(--v-ink-subtle);
  }
  .appr-t {
    font-size: var(--text-xs);
    color: var(--v-ink-title);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .fpv-approve {
    flex: none;
    font-size: 11px;
    padding: 4px 8px;
    border-radius: var(--radius-md);
    background: #e9f6ee;
    color: #2e7d4f;
    border: 1px solid rgba(46, 125, 79, 0.18);
    transition: transform 200ms ease, background 300ms ease, color 300ms ease;
  }
  .adone-row {
    font-size: var(--text-xs);
    color: var(--v-ink-sub);
    padding: 10px 2px;
    border-bottom: 1px solid var(--v-hairline);
    opacity: 0;
    transition: opacity 500ms ease;
  }
  .adone-row.show {
    opacity: 1;
    color: var(--v-ink-title);
  }

  /* narrow screens: flows stack vertically */
  @media (max-width: 899px) {
    .fp-flow {
      grid-template-columns: 1fr;
    }
    .flow-arrow {
      flex-direction: row;
    }
    .flow-arrow-line {
      height: 1px;
      width: auto;
      flex: 1;
    }
    .flow-arrow-tag {
      writing-mode: horizontal-tb;
    }
    .fp-appr {
      grid-template-columns: 1fr;
    }
    .appr-col:first-child {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid var(--v-hairline);
      padding-bottom: 16px;
      margin-bottom: 4px;
    }
  }
</style>

<script>
  // Flow animations — each visual demonstrates its feature's actual flow.
  // setInterval-driven (webview-safe); resting markup is complete without JS.
  (() => {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ---- 01: a source lights up → its extraction gets WRITTEN to the profile ----
    document.querySelectorAll('.fp-flow').forEach((visual) => {
      const srcs = Array.from(visual.querySelectorAll<HTMLElement>('.flow-src'));
      const rows = Array.from(visual.querySelectorAll<HTMLElement>('.flow-p-row'));
      const liveText = visual.querySelector<HTMLElement>('.flow-live-text');
      const tag = visual.querySelector<HTMLElement>('.flow-arrow-tag');
      let step = 0;
      setInterval(() => {
        if (step < srcs.length) {
          srcs.forEach((s) => s.classList.remove('on'));
          srcs[step].classList.add('on');
          tag?.classList.add('working');
          const row = rows[step];
          setTimeout(() => {
            row?.classList.add('written', 'landing');
            const chip = row?.querySelector('.fpv-chip');
            chip?.classList.add('fv-chip-pop');
            setTimeout(() => chip?.classList.remove('fv-chip-pop'), 500);
            if (liveText) liveText.textContent = 'updated just now';
            setTimeout(() => {
              row?.classList.remove('landing');
              tag?.classList.remove('working');
              if (liveText) liveText.textContent = 'up to date';
            }, 900);
          }, 650);
          step++;
        } else {
          // hold one beat with everything written, then start a fresh day
          srcs.forEach((s) => s.classList.remove('on'));
          rows.forEach((r) => r.classList.remove('written', 'landing'));
          step = 0;
        }
      }, 2100);
    });

    // ---- 02: the book — click through each client; detail panel follows ----
    document.querySelectorAll('.fp-book').forEach((visual) => {
      const items = Array.from(visual.querySelectorAll<HTMLElement>('.book3-item'));
      const details = Array.from(visual.querySelectorAll<HTMLElement>('.book3-detail'));
      if (items.length < 2 || items.length !== details.length) return;
      let idx = 0;
      setInterval(() => {
        const next = (idx + 1) % items.length;
        items[next].classList.add('pressed');
        setTimeout(() => {
          items[next].classList.remove('pressed');
          items.forEach((el, i) => el.classList.toggle('on', i === next));
          details.forEach((el, i) => el.classList.toggle('on', i === next));
          idx = next;
        }, 260);
      }, 3800);
    });

    // ---- 03: approve → items get crossed off and land in the ledger.
    // Runs ONCE each time the page becomes visible (ends at "all clear"),
    // and re-arms after you leave the section — a constant loop is too busy.
    document.querySelectorAll('.fp-appr').forEach((visual) => {
      const items = Array.from(visual.querySelectorAll<HTMLElement>('.appr-item'));
      const done = Array.from(visual.querySelectorAll<HTMLElement>('.adone-row'));
      const count = visual.querySelector<HTMLElement>('.appr-count');
      const el = visual as HTMLElement;
      const pendingFmt = el.dataset.pendingFmt ?? '{n} pending';
      const allClear = el.dataset.allclear ?? 'all clear — nothing waiting on you';
      const approveTxt = el.dataset.approve ?? '✓ Approve';
      const approvedTxt = el.dataset.approved ?? '✓ Approved';
      const pending = (n: number) => pendingFmt.replace('{n}', String(n));

      let step = 0;
      let timer: ReturnType<typeof setInterval> | null = null;
      let finished = false;

      const reset = () => {
        items.forEach((item) => {
          item.classList.remove('fv-active', 'crossed');
          const btn = item.querySelector<HTMLElement>('.fpv-approve');
          btn?.classList.remove('fv-clicked', 'fv-done');
          if (btn) btn.textContent = approveTxt;
        });
        done.forEach((d) => d.classList.remove('show'));
        if (count) count.textContent = pending(items.length);
        step = 0;
        finished = false;
      };

      const start = () => {
        if (timer || finished) return;
        timer = setInterval(() => {
          if (step < items.length) {
            const idx = step;
            const item = items[idx];
            const btn = item.querySelector<HTMLElement>('.fpv-approve');
            item.classList.add('fv-active');
            btn?.classList.add('fv-clicked');
            setTimeout(() => {
              btn?.classList.remove('fv-clicked');
              btn?.classList.add('fv-done');
              if (btn) btn.textContent = approvedTxt;
            }, 350);
            setTimeout(() => {
              item.classList.remove('fv-active');
              item.classList.add('crossed');
              const left = items.length - idx - 1;
              done[idx]?.classList.add('show');
              if (count) count.textContent = left > 0 ? pending(left) : allClear;
            }, 950);
            step++;
          } else {
            // day done — hold on "all clear" until the section is re-entered
            if (timer) clearInterval(timer);
            timer = null;
            finished = true;
          }
        }, 2500);
      };

      // Visibility watcher (setInterval — webview-safe). The vpin driver keeps
      // every page mounted inside the sticky viewport, so IO alone can't tell
      // which page is showing; check the page's computed visibility instead.
      const pageEl = (visual.closest('.vpin-page') ?? visual) as HTMLElement;
      const isShowing = () => {
        const r = pageEl.getBoundingClientRect();
        if (r.bottom <= 0 || r.top >= innerHeight || r.width === 0) return false;
        const cs = getComputedStyle(pageEl);
        return cs.visibility !== 'hidden' && parseFloat(cs.opacity || '1') > 0.6;
      };
      setInterval(() => {
        if (isShowing()) start();
        else if (finished) reset(); // left the section after a full run — re-arm
      }, 400);
    });
  })();
</script>
