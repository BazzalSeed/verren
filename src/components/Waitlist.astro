---
import SectionHeader from './SectionHeader.astro';
import { getCopy } from '../i18n/copy';
const t = getCopy(Astro.currentLocale);
const w = t.waitlist;
---

<section id="waitlist" class="py-24 md:py-32">
  <SectionHeader chip={w.chip} lead={w.title} />

  <div class="v-container mt-10 md:mt-14">
    <div class="v-grid">
      <div class="col-span-4 md:col-span-6 md:col-start-5">
        <p class="reveal reveal--fade max-w-[580px] text-h4 text-ink-body">
          <strong>{w.bodyLead}</strong>{w.bodyRest}
        </p>

        <form class="reveal mt-9 grid max-w-[480px] gap-4" id="waitlist-form" data-reveal-delay="100" novalidate>
          <div>
            <label class="wl-label" for="wl-name">{w.nameLabel}</label>
            <input class="wl-field" id="wl-name" name="name" type="text" autocomplete="name" />
          </div>
          <div>
            <label class="wl-label" for="wl-email">{w.emailLabel}</label>
            <input class="wl-field" id="wl-email" name="email" type="email" placeholder={w.emailPlaceholder} autocomplete="email" required />
            <p class="wl-field-error hidden" id="wl-email-hint">{w.emailError}</p>
          </div>
          <div>
            <label class="wl-label" for="wl-firm">{w.firmLabel}</label>
            <input class="wl-field" id="wl-firm" name="firm" type="text" placeholder={w.firmPlaceholder} autocomplete="url" />
            <p class="wl-field-error hidden" id="wl-firm-hint">{w.firmError}</p>
          </div>
          <div>
            <label class="wl-label" for="wl-crm">{w.crmLabel} <span class="wl-opt">{w.optional}</span></label>
            <input class="wl-field" id="wl-crm" name="crm" type="text" placeholder={w.crmPlaceholder} />
          </div>
          <div>
            <label class="wl-label" for="wl-note">{w.noteLabel} <span class="wl-opt">{w.optional}</span></label>
            <textarea class="wl-field" id="wl-note" name="note" rows="3"></textarea>
          </div>
          {/* Formspree extras: subject line + honeypot (bots fill it, humans never see it) */}
          <input type="hidden" name="_subject" value={w.subject} />
          <input class="hidden" type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <p class="wl-error hidden" id="wl-error" role="alert">{w.error}</p>
          <button class="v-btn v-btn--primary wl-submit" type="submit" id="wl-submit" data-sending={w.sending}>
            {w.submit} <span class="arrow">→</span>
          </button>
        </form>

        <div class="wl-success mt-9 hidden max-w-[480px] rounded-lg bg-brand-wash p-5 text-base text-ink-title" id="waitlist-success" role="status">
          {w.success}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .wl-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
    margin-bottom: 6px;
  }
  .wl-opt {
    color: var(--v-ink-subtle);
  }
  .wl-field {
    width: 100%;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    padding: 10px 13px;
    border-radius: var(--radius-md);
    border: 1px solid var(--v-border-moderate);
    background: var(--v-card);
    color: var(--v-ink-title);
    resize: vertical;
  }
  .wl-field:focus {
    outline: none;
    border-color: var(--v-brand-soft);
    box-shadow: 0 0 0 3px var(--v-brand-wash);
  }
  .wl-field-error {
    margin-top: 6px;
    font-size: var(--text-xs);
    color: #a04040;
  }
  .wl-error {
    font-size: var(--text-sm);
    color: #a04040;
  }
  .wl-submit {
    height: 34px;
    font-size: var(--text-sm);
    width: max-content;
  }
  .wl-submit[disabled] {
    opacity: 0.6;
    pointer-events: none;
  }
</style>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const success = document.getElementById('waitlist-success');
  const errorEl = document.getElementById('wl-error');
  const submitBtn = document.getElementById('wl-submit') as HTMLButtonElement | null;
  const submitHTML = submitBtn?.innerHTML ?? '';
  const emailEl = document.getElementById('wl-email') as HTMLInputElement | null;
  const emailHint = document.getElementById('wl-email-hint');

  const firmEl = document.getElementById('wl-firm') as HTMLInputElement | null;
  const firmHint = document.getElementById('wl-firm-hint');

  // Work email required — personal inboxes can't be verified for design partners.
  const PERSONAL = /@(gmail|googlemail|yahoo|ymail|hotmail|outlook|live|msn|icloud|me|mac|aol|proton|protonmail|pm|hey|gmx|zoho|qq|163|126|foxmail|yandex)\.[a-z.]+$/i;
  const emailValid = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) && !PERSONAL.test(v);
  const checkEmail = () => {
    const v = (emailEl?.value ?? '').trim();
    const bad = v.length > 0 && v.includes('@') && PERSONAL.test(v);
    emailHint?.classList.toggle('hidden', !bad);
    return !bad;
  };
  emailEl?.addEventListener('blur', checkEmail);

  // Firm website: accept "yourfirm.com" or full URLs; basic sanity check.
  const SITE_RE = /^(https?:\/\/)?([a-z0-9-]+\.)+[a-z]{2,}(\/\S*)?$/i;
  const checkFirm = () => {
    const v = (firmEl?.value ?? '').trim();
    const bad = v.length > 0 && !SITE_RE.test(v);
    firmHint?.classList.toggle('hidden', !bad);
    return !bad;
  };
  firmEl?.addEventListener('blur', checkFirm);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');
    const email = (emailEl?.value ?? '').trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailEl?.focus();
      emailEl?.reportValidity?.();
      return;
    }
    if (!checkEmail()) {
      emailEl?.focus();
      return;
    }
    if (!checkFirm()) {
      firmEl?.focus();
      return;
    }
    // normalize the site before it's submitted
    if (firmEl && firmEl.value.trim() && !/^https?:\/\//i.test(firmEl.value.trim())) {
      firmEl.value = 'https://' + firmEl.value.trim();
    }
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = submitBtn.dataset.sending ?? 'Sending…';
    }
    try {
      // Formspree — same account as seedzeng.com, delivers to the founders' inbox.
      // TODO: swap for a dedicated Verren form ID once created in Formspree.
      const res = await fetch('https://formspree.io/f/xknqwvlo', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      if (!res.ok) throw new Error(String(res.status));
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      errorEl?.classList.remove('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = submitHTML;
      }
    }
  });
</script>
