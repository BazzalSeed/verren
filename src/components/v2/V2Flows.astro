---
/**
 * V2Flows — the /v2 variant's replacement for the live Features section.
 * Same pinned three-page scrub ([data-vpin], driven from V2Layout), same
 * first-person voice — but the pages are the three revenue flows of an
 * advisory practice (Prospecting / Onboarding / Ongoing), each with a
 * live, layout-stable visual naming the tools in an advisor's real stack,
 * under the signature header ("What *Verren* does for you.").
 */
import PipelineVisual from './PipelineVisual.astro';
import RoadmapVisual from './RoadmapVisual.astro';
import DayVisual from './DayVisual.astro';
import { vc } from '../../content/v2';

interface FlowPage {
  num: string;
  id: string;
  title: string;
  body: string;
}
interface FlowsCopy {
  chip: string;
  /* plain header (/claude)… */
  title?: string;
  /* …or signature header (/claude-team): pre + hand-rendered "Verren" + post */
  titlePre?: string;
  titleHand?: string;
  titlePost?: string;
  pages: FlowPage[];
}
interface Props {
  /* per-variant section copy — /claude-team passes its own; defaults to
     /claude's. The three visuals are voice-neutral and shared. */
  flows?: FlowsCopy;
}
const f: FlowsCopy = Astro.props.flows ?? vc.flows;
const [p1, p2, p3] = f.pages;
---

<section id="features" class="pt-24 md:pt-32">
  <div class="vpin" data-vpin>
    <div class="vpin-sticky">
      <div class="vpin-head">
        {/* same molecule as SectionHeader, rendered inline so the title can
            carry the signature-hand "Verren" */}
        <div class="v-container md:border-t md:border-hairline md:pt-4">
          <div class="v-grid gap-y-4">
            <div class="col-span-4">
              <span class="v-chip reveal">{f.chip}</span>
            </div>
            <div class="col-span-4 md:col-span-6 md:col-start-5">
              <h2 class="reveal text-h1 text-ink-body" data-reveal-delay="80">
                {f.titleHand ? (
                  <strong>{f.titlePre} <span class="hand-inline">{f.titleHand}</span> {f.titlePost}</strong>
                ) : (
                  <strong>{f.title}</strong>
                )}
              </h2>
            </div>
            <div class="hidden md:col-span-2 md:col-start-11 md:flex md:justify-end">
              <div class="vpin-index" aria-hidden="true">
                {f.pages.map((p) => <span class="vpin-num">{p.num}</span>)}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 01 — Prospecting ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p1.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p1.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p1.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <PipelineVisual />
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 02 — Onboarding ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p2.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p2.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p2.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <RoadmapVisual />
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 03 — Ongoing ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">{p3.num}</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">{p3.title}</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">{p3.body}</p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <DayVisual />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fp-num {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: var(--text-xs);
    color: var(--v-ink-subtle);
  }
  /* the signature voice — same hand as the wordmark and the "— Verren"
     sign-off; slightly oversized because Caveat runs small at equal px */
  .hand-inline {
    font-family: var(--font-hand);
    font-weight: 600;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    transform: rotate(-2deg);
    padding-inline: 1px 3px;
    color: var(--v-ink-title);
  }
</style>
