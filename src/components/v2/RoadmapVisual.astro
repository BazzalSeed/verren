---
/**
 * Onboarding visual — the 12–18 month roadmap writes itself from meeting
 * notes while the document checklist ticks off beside it. Layout-stable:
 * roadmap rows brighten in place (no growth), checklist marks swap glyphs
 * inside a fixed circle. setInterval-driven; resting markup is complete.
 */
import { getV2Copy } from '../../content/v2';
const v = getV2Copy(Astro.currentLocale).onboardingVisual;
---

<div class="vco" aria-hidden="true" id="vco">
  <div class="vco-col vco-roadmap">
    <div class="vco-label">{v.roadmapLabel}</div>
    {v.roadmap.map((r) => (
      <div class="vco-row">
        <span class="vco-when">{r.when}</span>
        <span class="vco-text">{r.text}</span>
      </div>
    ))}
    <div class="vco-foot">{v.sourceNote}</div>
  </div>
  <div class="vco-col">
    <div class="vco-label">{v.checklistLabel}</div>
    {v.checklist.map((c) => (
      <div class="vco-check">
        <span class="vco-mark">✓</span>
        <span class="vco-check-text">{c}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .vco {
    border-radius: 14px;
    background: var(--v-card);
    border: 1px solid var(--v-border-subtle);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.05);
    padding: 22px 24px;
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 20px;
    align-items: start;
  }
  .vco-roadmap {
    border-right: 1px solid var(--v-hairline);
    padding-right: 20px;
  }
  .vco-label {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin-bottom: 10px;
  }
  .vco-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 2px;
    border-bottom: 1px solid var(--v-hairline);
    border-radius: 6px;
    transition: background 400ms ease;
  }
  .vco-row:last-of-type {
    border-bottom: none;
  }
  .vco-when {
    flex: none;
    width: 70px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: var(--radius-sm);
    background: var(--v-brand-wash);
    color: var(--v-brand);
    text-align: center;
    margin-top: 1px;
  }
  .vco-text {
    font-size: var(--text-xs);
    color: var(--v-ink-title);
    line-height: 1.5;
  }
  .vco-row.landing {
    background: var(--v-brand-wash);
  }
  /* the roadmap is a PLAN — the whole list shows upfront and Verren works
     through it (upcoming entries recede, the current one lands with the
     wash). The checklist is a LOG — items appear one by one as they're
     collected. Opacity/transform only; the card never changes height. */
  .vco-row {
    transition: opacity 550ms cubic-bezier(0.16, 1, 0.3, 1), background 400ms ease;
  }
  .vco-row.pending {
    opacity: 0.4;
  }
  @media (prefers-reduced-motion: no-preference) {
    :global(.js-anim) .vco-check {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 550ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 550ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    :global(.js-anim) .vco-check.on {
      opacity: 1;
      transform: none;
    }
  }
  .vco-foot {
    margin-top: 12px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
  }

  .vco-check {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 2px;
    border-bottom: 1px solid var(--v-hairline);
  }
  .vco-check:last-of-type {
    border-bottom: none;
  }
  .vco-mark {
    flex: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    background: #e9f6ee;
    color: #2e7d4f;
  }
  .vco-check-text {
    font-size: var(--text-xs);
    color: var(--v-ink-title);
  }

  @media (max-width: 640px) {
    .vco {
      grid-template-columns: 1fr;
      padding: 18px 16px;
    }
    .vco-roadmap {
      border-right: none;
      padding-right: 0;
      border-bottom: 1px solid var(--v-hairline);
      padding-bottom: 14px;
    }
  }
</style>

<script>
  // Roadmap entries and checklist items APPEAR one by one as Verren writes
  // them — planning and paperwork advance together, then the finished
  // roadmap HOLDS. Plays once each time the page becomes visible; re-arms
  // after you leave the section.
  (() => {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const root = document.getElementById('vco');
    if (!root) return;
    const rows = Array.from(root.querySelectorAll<HTMLElement>('.vco-row'));
    const checks = Array.from(root.querySelectorAll<HTMLElement>('.vco-check'));
    const n = Math.max(rows.length, checks.length);

    let step = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let finished = false;

    const reset = () => {
      rows.forEach((r) => {
        r.classList.add('pending');
        r.classList.remove('landing');
      });
      checks.forEach((c) => c.classList.remove('on'));
      step = 0;
      finished = false;
    };

    const start = () => {
      if (timer || finished) return;
      const tick = () => {
        if (step < n) {
          const row = rows[step];
          if (row) {
            row.classList.remove('pending');
            row.classList.add('landing');
            setTimeout(() => row.classList.remove('landing'), 900);
          }
          checks[step]?.classList.add('on');
          step++;
        } else {
          // roadmap complete — hold until the section is re-entered
          if (timer) clearInterval(timer);
          timer = null;
          finished = true;
        }
      };
      tick(); // first item appears immediately — no empty-card beat
      timer = setInterval(tick, 1400);
    };

    const pageEl = (root.closest('.vpin-page') ?? root) as HTMLElement;
    const isShowing = () => {
      const r = pageEl.getBoundingClientRect();
      if (r.bottom <= 0 || r.top >= innerHeight || r.width === 0) return false;
      const cs = getComputedStyle(pageEl);
      return cs.visibility !== 'hidden' && parseFloat(cs.opacity || '1') > 0.6;
    };
    reset();
    setInterval(() => {
      if (isShowing()) start();
      else if (finished) reset();
    }, 400);
  })();
</script>
