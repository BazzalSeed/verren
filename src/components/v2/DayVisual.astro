---
/**
 * Ongoing visual — one day across the book. Routine rows complete on their
 * own; the two consequential rows (trading, money movement) wait on an
 * Approve button that gets "clicked" — approval-gating shown, not claimed.
 * Layout-stable: statuses swap inside fixed-width slots; approve buttons
 * change class/text only. setInterval-driven; resting markup shows the
 * completed day.
 */
import { getV2Copy } from '../../content/v2';
const v = getV2Copy(Astro.currentLocale).ongoingVisual;
---

<div class="vcd" aria-hidden="true" id="vcd" data-approve={v.approve} data-approved={v.approved} data-logged={v.logged}>
  <div class="vcd-label">
    {v.label}
    <span class="vcd-live"><span class="dot v-live-dot"></span> live</span>
  </div>
  {v.rows.map((r) => (
    <div class:list={['vcd-row', r.status === 'approval' && 'vcd-row--appr']} data-kind={r.status}>
      <span class="vcd-tool">{r.tool}</span>
      <span class="vcd-text">{r.text}</span>
      {r.status === 'approval' ? (
        <span class="vcd-approve logged">{v.logged}</span>
      ) : (
        <span class="vcd-status">{r.status}</span>
      )}
    </div>
  ))}
  <div class="vcd-foot">{v.foot}</div>
</div>

<style>
  .vcd {
    border-radius: 14px;
    background: var(--v-card);
    border: 1px solid var(--v-border-subtle);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.05);
    padding: 22px 24px;
  }
  .vcd-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin-bottom: 8px;
  }
  .vcd-live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    letter-spacing: 0.06em;
  }
  .vcd-live .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4caf6d;
  }
  .vcd-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 2px;
    border-bottom: 1px solid var(--v-hairline);
    border-radius: 6px;
    transition: background 400ms ease;
  }
  .vcd-row:last-of-type {
    border-bottom: none;
  }
  .vcd-row.active {
    background: var(--v-fill);
  }
  .vcd-tool {
    flex: none;
    width: 84px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: var(--radius-sm);
    background: var(--v-brand-wash);
    color: var(--v-brand);
    text-align: center;
  }
  .vcd-text {
    flex: 1;
    min-width: 0;
    font-size: var(--text-sm);
    color: var(--v-ink-title);
    line-height: 1.4;
  }
  .vcd-status {
    flex: none;
    width: 92px;
    text-align: right;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #2e7d4f;
  }
  /* the day view is a LOG — the morning's three done lines show upfront;
     the two approval rows arrive one by one, get approved, and settle to
     "done · logged". Opacity/transform only; the card never changes height. */
  @media (prefers-reduced-motion: no-preference) {
    :global(.js-anim) .vcd-row--appr {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 550ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 550ms cubic-bezier(0.16, 1, 0.3, 1),
        background 400ms ease;
    }
    :global(.js-anim) .vcd-row--appr.on {
      opacity: 1;
      transform: none;
    }
  }
  .vcd-approve {
    flex: none;
    width: 92px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    padding: 4px 0;
    border-radius: var(--radius-md);
    background: #e9f6ee;
    color: #2e7d4f;
    border: 1px solid rgba(46, 125, 79, 0.18);
    transition: transform 200ms ease, background 300ms ease, color 300ms ease, opacity 300ms ease, border-color 300ms ease;
  }
  /* after approval the button settles into the same quiet log line as the
     morning's rows — approved things become history */
  .vcd-approve.logged {
    background: transparent;
    border-color: transparent;
    justify-content: flex-end;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #2e7d4f;
  }
  .vcd-foot {
    margin-top: 12px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
  }

  @media (max-width: 640px) {
    .vcd {
      padding: 18px 16px;
    }
    .vcd-tool {
      width: 72px;
    }
    .vcd-status,
    .vcd-approve {
      width: 84px;
    }
  }
</style>

<script>
  // The morning's three done lines show upfront; the two approval rows
  // arrive one by one: Approve appears → gets "clicked" (fv-clicked/fv-done
  // from global.css) → settles to "done · logged" like the rest of the log.
  // Plays once each time the page becomes visible; re-arms after you leave.
  (() => {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const root = document.getElementById('vcd');
    if (!root) return;
    const apprRows = Array.from(root.querySelectorAll<HTMLElement>('.vcd-row--appr'));
    const approveTxt = root.dataset.approve ?? '✓ Approve';
    const approvedTxt = root.dataset.approved ?? '✓ Approved';
    const loggedTxt = root.dataset.logged ?? 'done · logged';

    let step = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    let finished = false;

    const reset = () => {
      apprRows.forEach((r) => {
        r.classList.remove('on', 'active');
        const btn = r.querySelector<HTMLElement>('.vcd-approve');
        if (btn) {
          btn.classList.remove('fv-clicked', 'fv-done', 'logged');
          btn.textContent = approveTxt;
        }
      });
      step = 0;
      finished = false;
    };

    const start = () => {
      if (timer || finished) return;
      const tick = () => {
        if (step < apprRows.length) {
          const row = apprRows[step];
          const btn = row.querySelector<HTMLElement>('.vcd-approve');
          row.classList.add('on', 'active');
          // the ask appears, you click, it's approved, it becomes history —
          // same one-way rhythm as the live site's approval visuals
          setTimeout(() => btn?.classList.add('fv-clicked'), 900);
          setTimeout(() => {
            btn?.classList.remove('fv-clicked');
            btn?.classList.add('fv-done');
            if (btn) btn.textContent = approvedTxt;
          }, 1250);
          setTimeout(() => {
            btn?.classList.remove('fv-done');
            btn?.classList.add('logged');
            if (btn) btn.textContent = loggedTxt;
            row.classList.remove('active');
          }, 2500);
          step++;
        } else {
          // day done — hold until the section is re-entered
          if (timer) clearInterval(timer);
          timer = null;
          finished = true;
        }
      };
      tick(); // first approval appears immediately — no empty beat
      timer = setInterval(tick, 3100);
    };

    const pageEl = (root.closest('.vpin-page') ?? root) as HTMLElement;
    const isShowing = () => {
      const r = pageEl.getBoundingClientRect();
      if (r.bottom <= 0 || r.top >= innerHeight || r.width === 0) return false;
      const cs = getComputedStyle(pageEl);
      return cs.visibility !== 'hidden' && parseFloat(cs.opacity || '1') > 0.6;
    };
    reset();
    setInterval(() => {
      if (isShowing()) start();
      else if (finished) reset();
    }, 400);
  })();
</script>
