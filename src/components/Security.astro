---
/**
 * Security — pinned three-page deep dive (shared [data-vpin] driver):
 *   01 — our models, our private cloud; nothing leaves, nothing trains
 *   02 — built to the standards advisory firms answer to
 *   03 — approval-gated by design, audit trail on everything
 * No badges, no certification claims until real. Visuals are flow diagrams.
 */
import SectionHeader from './SectionHeader.astro';
---

<section id="security" class="pt-24 md:pt-32">
  <div class="vpin" data-vpin>
    <div class="vpin-sticky">
      <div class="vpin-head">
        <SectionHeader chip="Security" lead="Your clients' data is not training data.">
          <div class="vpin-index" slot="aside" aria-hidden="true">
            <span class="vpin-num">01</span>
            <span class="vpin-num">02</span>
            <span class="vpin-num">03</span>
          </div>
        </SectionHeader>
      </div>

      <!-- ============ 01 — our models, our cloud ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">01</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">Your data, our models</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">
                Verren runs open-weight models on infrastructure we control. Client
                data is never sent to a third-party AI provider — and nothing you
                capture ever trains a model. Your book of business stays your book
                of business.
              </p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div class="fp-visual sec-cloud" aria-hidden="true">
                <div class="sec-boundary">
                  <div class="sec-boundary-title">Verren private cloud</div>
                  <div class="sec-boundary-sub">Infrastructure we control</div>
                  <div class="sec-inside">
                    <div class="sec-node">Your client data</div>
                    <div class="sec-link"><span class="sec-link-line"></span><span class="sec-link-tag">processed inside</span><span class="sec-link-line"></span></div>
                    <div class="sec-node">Our open-weight models</div>
                  </div>
                </div>
                <div class="sec-never">
                  <span class="sec-block">✕</span>
                  <span class="sec-never-text"><strong>Never sent to a third-party AI provider</strong> — not OpenAI, not Anthropic, not Google.</span>
                </div>
                <div class="sec-never">
                  <span class="sec-block">✕</span>
                  <span class="sec-never-text"><strong>Never used to train a model</strong> — your book of business stays yours.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 02 — the standards ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">02</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">Built to the standards your firm answers to</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">
                Designed around the rules that govern advisory firms — safeguarding,
                AI governance, books and records. When your CCO asks where client
                data goes, you'll have the best answer in the industry. And your DDQ
                gets answered by the founders who built the system.
              </p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div class="fp-visual sec-comp" aria-hidden="true">
                <div class="flow-label">Designed for</div>
                <div class="sec-check">
                  <span class="sec-tick">✓</span>
                  <span class="sec-check-main">
                    <span class="sec-check-t">Reg S-P — safeguarding</span>
                    <span class="sec-check-d">Client records protected; incident response built in</span>
                  </span>
                </div>
                <div class="sec-check">
                  <span class="sec-tick">✓</span>
                  <span class="sec-check-main">
                    <span class="sec-check-t">FINRA 2026 GenAI guidance</span>
                    <span class="sec-check-d">Human-in-the-loop controls · prompt &amp; output logging · model-version records</span>
                  </span>
                </div>
                <div class="sec-check">
                  <span class="sec-tick">✓</span>
                  <span class="sec-check-main">
                    <span class="sec-check-t">SEC AI exam priorities</span>
                    <span class="sec-check-d">AI governance your examiner can actually inspect</span>
                  </span>
                </div>
                <div class="sec-check">
                  <span class="sec-tick">✓</span>
                  <span class="sec-check-main">
                    <span class="sec-check-t">Books &amp; records — 204-2 / 17a-4</span>
                    <span class="sec-check-d">Retention the way advisers are required to keep it</span>
                  </span>
                </div>
                <div class="sec-check">
                  <span class="sec-tick">✓</span>
                  <span class="sec-check-main">
                    <span class="sec-check-t">Encryption &amp; access</span>
                    <span class="sec-check-d">Encrypted in transit and at rest · least-privilege access</span>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ 03 — approval + audit ============ -->
      <div class="vpin-page">
        <div class="v-container w-full">
          <div class="v-grid items-center gap-y-10">
            <div class="col-span-4 md:col-span-4">
              <div class="fp-num">03</div>
              <h3 class="mt-2 max-w-[330px] text-h3 text-ink-title">Nothing moves without you. Everything leaves a trail.</h3>
              <p class="mt-3 max-w-[330px] text-base text-ink-body">
                Every action is proposed first, shown in full, and runs only on your
                approval. Every read, write, prompt, and output is logged with model
                and timestamp — evidence you can hand to an examiner.
              </p>
            </div>
            <div class="col-span-4 md:col-span-7 md:col-start-6">
              <div class="fp-visual sec-audit" aria-hidden="true">
                <div class="sec-gate">
                  <div class="sec-gate-action">
                    <span class="appr-t">Send follow-up — Priya Natarajan</span>
                    <span class="fpv-approve">✓ Approve</span>
                  </div>
                </div>
                <div class="flow-label sec-ledger-label">Audit trail</div>
                <div class="sec-log">
                  <div class="sec-log-row">09:41:22 · draft_email · shown in full · approved by you · model vx-70b</div>
                  <div class="sec-log-row">09:41:24 · send_email · executed · logged with prompt + output</div>
                  <div class="sec-log-row">09:44:03 · profile_write · goal added · source: meeting transcript</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .fp-num {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: var(--text-xs);
    color: var(--v-ink-subtle);
  }
  .fp-visual {
    border-radius: 14px;
    background: var(--v-card);
    border: 1px solid var(--v-border-subtle);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.05);
    padding: 22px 24px;
  }
  .flow-label {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
    margin-bottom: 12px;
  }
  .flow-foot {
    margin-top: 14px;
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--v-ink-subtle);
  }

  /* ---------- 01: the private-cloud boundary ---------- */
  .sec-boundary {
    border: 1px solid var(--v-border-moderate);
    border-radius: 10px;
    padding: 16px 18px;
    background: var(--v-surface);
  }
  .sec-inside {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    align-items: center;
  }
  .sec-node {
    border: 1px solid var(--v-hairline);
    border-radius: 8px;
    background: var(--v-card);
    padding: 12px 14px;
    font-size: var(--text-sm);
    color: var(--v-ink-title);
    text-align: center;
  }
  .sec-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    min-width: 90px;
  }
  .sec-link-line {
    width: 100%;
    height: 1px;
    background: var(--v-border-moderate);
  }
  .sec-link-tag {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--v-ink-hint);
    white-space: nowrap;
  }
  .sec-boundary-title {
    font-size: var(--text-base);
    color: var(--v-ink-title);
  }
  .sec-boundary-sub {
    font-size: var(--text-xs);
    color: var(--v-ink-hint);
    margin-bottom: 14px;
  }
  /* two plain statements — no ambiguity, no decoration to decode */
  .sec-never {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 13px 2px 0;
  }
  .sec-block {
    flex: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    border: 1px solid rgba(160, 64, 64, 0.35);
    color: #a04040;
    background: rgba(160, 64, 64, 0.06);
    margin-top: 1px;
  }
  .sec-never-text {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--v-ink-body);
  }

  /* ---------- 02: the standards ---------- */
  .sec-check {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 11px 2px;
    border-bottom: 1px solid var(--v-hairline);
  }
  .sec-check:last-of-type {
    border-bottom: none;
  }
  .sec-tick {
    flex: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    background: #e9f6ee;
    color: #2e7d4f;
    margin-top: 1px;
  }
  @media (prefers-color-scheme: dark) {
    .sec-tick {
      background: rgba(76, 175, 109, 0.15);
      color: #7fd99b;
    }
  }
  .sec-check-main {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .sec-check-t {
    font-size: var(--text-sm);
    color: var(--v-ink-title);
  }
  .sec-check-d {
    font-size: var(--text-xs);
    color: var(--v-ink-body);
  }

  /* ---------- 03: gate + ledger ---------- */
  .sec-gate-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--v-hairline);
    border-radius: 8px;
    background: var(--v-surface);
    padding: 12px 14px;
  }
  .appr-t {
    font-size: var(--text-sm);
    color: var(--v-ink-title);
  }
  .fpv-approve {
    flex: none;
    font-size: 11px;
    padding: 4px 8px;
    border-radius: var(--radius-md);
    background: #e9f6ee;
    color: #2e7d4f;
    border: 1px solid rgba(46, 125, 79, 0.18);
    transition: transform 200ms ease, background 300ms ease, color 300ms ease;
  }
  @media (prefers-color-scheme: dark) {
    .fpv-approve {
      background: rgba(76, 175, 109, 0.15);
      color: #7fd99b;
      border-color: rgba(76, 175, 109, 0.25);
    }
  }
  .sec-ledger-label {
    margin-top: 18px;
  }
  .sec-log {
    border: 1px solid var(--v-hairline);
    border-radius: 8px;
    padding: 6px 12px;
    background: var(--v-surface);
  }
  .sec-log-row {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 10px;
    line-height: 1.6;
    color: var(--v-ink-sub);
    padding: 7px 0;
    border-bottom: 1px solid var(--v-hairline);
  }
  .sec-log-row:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 899px) {
    .sec-cloud {
      grid-template-columns: 1fr;
    }
  }
</style>
