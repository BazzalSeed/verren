---
/**
 * /v2 — the converged concept variant. Unlisted + noindex; reachable by URL, not linked from the live nav.
 * The live site with three changes:
 *   1. Outcome hero — "Grow your book. Verren does the rest." with the
 *      chief-of-staff identity and the three flows named in the sub, and
 *      the audience label rendered loud (the headline's address line).
 *   2. Features replaced by the three flows (docs/tyler-flows.md) under
 *      the signature header "What *Verren* does for you."
 *   3. Everything else — Problem, Introducing, Security, Team, Waitlist —
 *      is the live components imported READ-ONLY; they render exactly as
 *      on the live site and stay in sync with it.
 * Design history: docs/superpowers/specs/2026-07-19-three-copy-positioning-design.md
 */
import V2Layout from '../../layouts/V2Layout.astro';
import V2Hero from '../../components/v2/V2Hero.astro';
import Problem from '../../components/Problem.astro';
import Introducing from '../../components/Introducing.astro';
import V2Flows from '../../components/v2/V2Flows.astro';
import Security from '../../components/Security.astro';
import Founders from '../../components/Founders.astro';
import Waitlist from '../../components/Waitlist.astro';
---

<V2Layout>
  <V2Hero loudLabel />
  <Problem />
  <Introducing />
  <V2Flows />
  <Security />
  <Founders />
  <Waitlist />
</V2Layout>
