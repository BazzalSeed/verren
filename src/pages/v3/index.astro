---
/**
 * /v3 — concept variant. Unlisted + noindex; reachable by URL, not linked from the live nav.
 * /v2 (frozen) with ONE change: the Problem section becomes the lifecycle
 * arc (V3Problem) so it maps 1:1 onto the flows — winning is expensive →
 * onboarding kills momentum → keeping the book never stops. Hero and flows
 * are /v2's; Introducing, Security, Team, Waitlist are the live components
 * imported READ-ONLY. Design history: docs/superpowers/specs/
 * 2026-07-19-three-copy-positioning-design.md
 */
import V2Layout from '../../layouts/V2Layout.astro';
import V2Hero from '../../components/v2/V2Hero.astro';
import V3Problem from '../../components/v2/V3Problem.astro';
import Introducing from '../../components/Introducing.astro';
import V2Flows from '../../components/v2/V2Flows.astro';
import Security from '../../components/Security.astro';
import Founders from '../../components/Founders.astro';
import Waitlist from '../../components/Waitlist.astro';
import { v3 } from '../../content/v3';
---

<V2Layout meta={v3.meta}>
  <V2Hero loudLabel />
  <V3Problem />
  <Introducing />
  <V2Flows />
  <Security />
  <Founders />
  <Waitlist />
</V2Layout>
